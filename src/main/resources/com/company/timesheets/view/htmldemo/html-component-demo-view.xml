<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://htmlComponentDemoView.title">
    <!-- Экран для тренинга: сравнивает вывод одной и той же HTML-строки разными компонентами. -->
    <layout width="100%" classNames="p-l spacing-l">
        <vbox width="100%" classNames="spacing-s">
            <h2 text="msg://htmlComponentDemoView.heading"/>
            <span text="msg://htmlComponentDemoView.intro"/>
        </vbox>

        <details summaryText="msg://htmlComponentDemoView.cdataSummary" opened="true">
            <html id="cdataHtml">
                <content>
                <![CDATA[
                <div>
                    <p><b>CDATA</b> is needed only when you embed raw HTML directly into the XML descriptor.</p>
                    <p>The XML parser must ignore tags like <code>&lt;div&gt;</code> and <code>&lt;b&gt;</code>, otherwise it treats them as XML nodes instead of Html component content.</p>
                    <pre>&lt;html id="helpHtml"&gt;
    &lt;![CDATA[
    &lt;div&gt;
        &lt;h3&gt;Briefing&lt;/h3&gt;
        &lt;p&gt;Read the instructions before signing.&lt;/p&gt;
    &lt;/div&gt;
    ]]&gt;
&lt;/html&gt;</pre>
                    <p><b>Important:</b> Vaadin <code>Html</code> requires exactly one root element, so wrap the fragment in one outer <code>&lt;div&gt;</code>.</p>
                </div>
                ]]>
                </content>
            </html>
        </details>

        <h3 text="msg://htmlComponentDemoView.compareHeading"/>
        <span text="msg://htmlComponentDemoView.compareIntro"/>

        <hbox width="100%" classNames="spacing-l items-start">
            <vbox width="33%" classNames="spacing-s">
                <h4 text="msg://htmlComponentDemoView.spanTitle"/>
                <span id="spanExample"/>
                <span text="msg://htmlComponentDemoView.spanExplanation"/>
            </vbox>
            <vbox width="33%" classNames="spacing-s">
                <h4 text="msg://htmlComponentDemoView.textAreaTitle"/>
                <textArea id="textAreaExample"
                          readOnly="true"
                          width="100%"
                          height="18em"/>
                <span text="msg://htmlComponentDemoView.textAreaExplanation"/>
            </vbox>
            <vbox width="33%" classNames="spacing-s">
                <h4 text="msg://htmlComponentDemoView.htmlTitle"/>
                <html id="dynamicHtmlExample">
                    <content>
                    <![CDATA[
                    <div>Placeholder</div>
                    ]]>
                    </content>
                </html>
                <span text="msg://htmlComponentDemoView.htmlExplanation"/>
            </vbox>
        </hbox>

        <details summaryText="msg://htmlComponentDemoView.whenToUseSummary">
            <html id="usageHtml">
                <content>
                <![CDATA[
                <div>
                    <ul>
                        <li><b>Use Span</b> when you need plain text and automatic escaping.</li>
                        <li><b>Use TextArea</b> when you want to show or edit the HTML source itself.</li>
                        <li><b>Use Html</b> when you want the browser to render the markup as headings, lists, emphasis and links.</li>
                    </ul>
                </div>
                ]]>
                </content>
            </html>
        </details>
    </layout>
</view>
