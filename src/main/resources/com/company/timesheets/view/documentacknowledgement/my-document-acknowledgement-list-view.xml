<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://myDocumentAcknowledgementListView.title"
      focusComponent="acknowledgementsDataGrid">
    <!-- Личный список карточек ознакомления текущего пользователя. -->
    <data readOnly="true">
        <collection id="acknowledgementsDc"
                    class="com.company.timesheets.entity.DocumentAcknowledgement">
            <fetchPlan extends="_base">
                <property name="document" fetchPlan="_base"/>
                <property name="user" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="acknowledgementsDl" readOnly="true">
                <query>
                    <![CDATA[select e from ts_DocumentAcknowledgement e
                        where e.user.username = :current_user_username
                        order by e.sentAt desc]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <layout>
        <genericFilter id="genericFilter" dataLoader="acknowledgementsDl">
            <properties include=".*"/>
        </genericFilter>
        <hbox id="buttonsPanel" classNames="buttons-panel">
            <button id="editBtn" action="acknowledgementsDataGrid.edit"/>
            <simplePagination id="pagination" dataLoader="acknowledgementsDl"/>
        </hbox>
        <dataGrid id="acknowledgementsDataGrid"
                  dataContainer="acknowledgementsDc"
                  width="100%">
            <actions>
                <action id="edit" type="list_edit"/>
            </actions>
            <columns resizable="true">
                <column property="document"/>
                <column property="status" autoWidth="true"/>
                <column property="sentAt" autoWidth="true"/>
                <column property="viewedAt" autoWidth="true"/>
                <column property="signedAt" autoWidth="true"/>
            </columns>
        </dataGrid>
    </layout>
</view>
